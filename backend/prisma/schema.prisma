generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// System role controlling access level. ADMIN has full CRUD access; USER has read-only access.
enum UserRole {
  ADMIN
  USER
}

/// System user account. Used for authentication in local-auth mode.
/// In OIDC mode the password field is unused; identity is verified via JWKS.
model User {
  id        String   @id @default(cuid())
  /// Login email, must be unique across the system.
  email     String   @unique
  password  String
  /// Display name shown in UI; optional.
  name      String?
  role      UserRole @default(USER)
  /// Soft-disable without deleting — preserves audit history.
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
