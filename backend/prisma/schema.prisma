generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Default policy controlling how permission checks behave for a role.
/// DENY_ALL: only explicitly granted permissions pass (default for all new roles).
/// READ_ALL: all *_READ permissions pass automatically; writes/deletes require explicit grants.
/// ALLOW_ALL: every permission check passes — custom ADMIN-level bypass for non-system roles.
enum PermissionPolicy {
  DENY_ALL
  READ_ALL
  ALLOW_ALL
}

/// Granular permission assignable to a custom Role. ADMIN bypasses all checks;
/// these values are only evaluated for non-ADMIN roles. Embedded in the JWT at login.
enum Permission {
  // User management
  USERS_READ
  USERS_CREATE
  USERS_UPDATE
  USERS_DELETE
  // API key management
  API_KEYS_READ
  API_KEYS_CREATE
  API_KEYS_DELETE
  // Drive — files
  DRIVE_FILE_READ
  DRIVE_FILE_CREATE
  DRIVE_FILE_UPDATE
  DRIVE_FILE_DELETE
  // Drive — folders
  DRIVE_FOLDER_READ
  DRIVE_FOLDER_CREATE
  DRIVE_FOLDER_UPDATE
  DRIVE_FOLDER_DELETE
  // Space management
  SPACE_MANAGE
  DRIVE_FILE_SHARE
}

/// Role a user holds within a Space. Determines what actions they may perform on Space content.
enum SpaceRole {
  OWNER  // rename/delete the space, manage members and role grants, all file operations
  EDITOR // create, rename, move, trash, restore, permanently delete files and folders
  VIEWER // read and download only; cannot modify content
}

/// System role or custom role. ADMIN and USER are seeded system roles and cannot be deleted. @internal
/// Marked @internal so MetaService excludes it from the API-key scope catalog.
model Role {
  id               String           @id @default(cuid())
  /// Unique machine name, e.g. "ADMIN", "USER", "EDITOR". Used in JWT roleName field.
  name             String           @unique
  /// Human-readable label shown in UI.
  displayName      String           @map("display_name")
  /// System roles (ADMIN / USER) cannot be deleted or renamed.
  isSystem         Boolean          @default(false) @map("is_system")
  /// Default deny; explicit permissions in RolePermission are additive on top of the policy.
  permissionPolicy PermissionPolicy @default(DENY_ALL) @map("permission_policy")
  permissions      RolePermission[]
  userRoles        UserRole[]
  apiKeys          ApiKey[]
  spaceRoleGrants  SpaceRoleGrant[] @relation("SpaceRoleGrants")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

/// Junction table between Role and Permission enum values. @internal
/// Marked @internal so MetaService excludes it from the auto-derived scope catalog.
model RolePermission {
  id         String     @id @default(cuid())
  roleId     String     @map("role_id")
  permission Permission
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("role_permissions")
}

/// Junction table between User and Role.
model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

/// System user account. Used for authentication in local-auth mode.
/// In OIDC mode the password field is unused; identity is verified via JWKS.
model User {
  id               String          @id @default(cuid())
  /// Login email, must be unique across the system.
  email            String          @unique
  password         String
  /// Display name shown in UI; optional.
  name             String?
  userRoles        UserRole[]
  /// Soft-disable without deleting — preserves audit history.
  isActive         Boolean         @default(true) @map("is_active")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  spaceMemberships SpaceMember[]   @relation("SpaceMemberships")
  createdSpaces    Space[]         @relation("SpaceCreator")
  createdFolders   DriveFolder[]   @relation("FolderCreator")
  createdFiles     DriveFile[]     @relation("FileCreator")

  @@map("users")
}

/// Machine-to-machine API key for external integrations (n8n, AI agents).
/// Created by ADMIN only. Raw key is shown once at creation and never stored. @internal
model ApiKey {
  id         String    @id @default(cuid())
  /// Human-readable label, e.g. "n8n production" or "AI agent read-only".
  name       String
  /// First 16 chars of the raw key, shown in lists for identification (e.g. "an_live_a1b2c3d4").
  prefix     String
  /// SHA-256 hash of the raw key. The raw key is never persisted.
  hashedKey  String    @unique @map("hashed_key")
  /// Role this key authenticates as; FK to roles table.
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id])
  /// Module-level scopes, e.g. ["users:read","employees:*"]. "*" = all scopes. Empty = deny all.
  scopes     String[]
  /// Requests per minute. null = system default (60).
  rateLimit  Int?      @map("rate_limit")
  /// Whether this key can be used. Set false to revoke without deleting.
  isActive   Boolean   @default(true) @map("is_active")
  /// Optional expiry. null = never expires.
  expiresAt  DateTime? @map("expires_at")
  /// Email of the ADMIN who created this key. Snapshot string, no FK.
  createdBy  String?   @map("created_by")
  /// Timestamp of last successful authentication with this key.
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
}

/// A collaborative workspace that owns all Drive content within it.
/// Every folder and file belongs to exactly one Space.
model Space {
  id          String           @id @default(cuid())
  /// Display name shown in the sidebar, e.g. "Engineering Docs".
  name        String
  /// Optional one-line description shown on the Space overview page.
  description String?
  /// User who created the space; null if the creator has since been deleted.
  createdById String?          @map("created_by_id")
  createdBy   User?            @relation("SpaceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members     SpaceMember[]
  roleGrants  SpaceRoleGrant[]
  folders     DriveFolder[]
  files       DriveFile[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("spaces")
}

/// Explicit per-user membership in a Space. @internal
/// Takes precedence over role-based grants when the resolved SpaceRole is higher
/// (e.g. a VIEWER-role user promoted to OWNER of a specific space).
model SpaceMember {
  id        String    @id @default(cuid())
  spaceId   String    @map("space_id")
  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation("SpaceMemberships", fields: [userId], references: [id], onDelete: Cascade)
  spaceRole SpaceRole @map("space_role")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([spaceId, userId])
  @@map("space_members")
}

/// Grants all users holding a system Role a SpaceRole within a Space. @internal
/// Primary use case: department spaces — assign a department Role (e.g. "Marketing")
/// so every member of that department automatically gets access without manual user-by-user setup.
model SpaceRoleGrant {
  id           String    @id @default(cuid())
  spaceId      String    @map("space_id")
  space        Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /// The system Role (from roles table) being granted access to this Space.
  systemRoleId String    @map("system_role_id")
  systemRole   Role      @relation("SpaceRoleGrants", fields: [systemRoleId], references: [id], onDelete: Cascade)
  spaceRole    SpaceRole @map("space_role")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([spaceId, systemRoleId])
  @@map("space_role_grants")
}

/// Storage folder for organising files. Supports nested hierarchy via parentId.
model DriveFolder {
  id          String        @id @default(cuid())
  /// Display name shown in the file browser.
  name        String
  /// Space this folder belongs to.
  spaceId     String        @map("space_id")
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /// User who created this folder; null if the creator has since been deleted.
  createdById String?       @map("created_by_id")
  createdBy   User?         @relation("FolderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Parent folder; null means root of the Space.
  parentId    String?       @map("parent_id")
  parent      DriveFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    DriveFolder[] @relation("FolderTree")
  files       DriveFile[]
  /// Soft-delete — trashed folders hidden from normal view.
  isTrashed   Boolean       @default(false) @map("is_trashed")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("drive_folders")
}

/// Uploaded file metadata. Actual binary is stored in an external object store.
model DriveFile {
  id          String       @id @default(cuid())
  /// Original filename as uploaded.
  name        String
  /// MIME type detected at upload time, e.g. "image/png".
  mimeType    String       @map("mime_type")
  /// File size in bytes.
  size        Int
  /// Path or key in the external object store (S3-compatible).
  storagePath String       @map("storage_path")
  /// Space this file belongs to.
  spaceId     String       @map("space_id")
  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /// User who uploaded or created this file; null if the creator has since been deleted.
  createdById String?      @map("created_by_id")
  createdBy   User?        @relation("FileCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Containing folder; null means root of the Space.
  folderId    String?      @map("folder_id")
  folder      DriveFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  /// Soft-delete flag.
  isTrashed   Boolean      @default(false) @map("is_trashed")
  /// Monotonically increasing version counter; incremented on each online-editor save.
  version     Int          @default(1)
  /// WOPI lock token held by the Collabora server during an active edit session.
  lockToken   String?      @map("lock_token")
  /// User ID that holds the current lock.
  lockedBy    String?      @map("locked_by")
  /// Timestamp when the lock was acquired or last refreshed.
  lockedAt    DateTime?    @map("locked_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("drive_files")
}
