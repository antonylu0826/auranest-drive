# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/app_db

# ── Standalone (local auth) ──────────────────────────────
AUTH_MODE=local
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── SSO / OIDC (Keycloak etc.) ───────────────────────────
# AUTH_MODE=oidc
# OIDC_JWKS_URL=https://keycloak.example.com/realms/auranest/protocol/openid-connect/certs
# OIDC_ISSUER=https://keycloak.example.com/realms/auranest
# OIDC_AUDIENCE=account

# Ports (Drive app: 3010 / 3011)
PORT=3010
BACKEND_PORT=3010
FRONTEND_PORT=3011

# Collabora Online (WOPI)
WOPI_TOKEN_SECRET=change-me-in-production
WOPI_TOKEN_TTL_SEC=3600
COLLABORA_URL=http://localhost:9980
# WOPI_PUBLIC_URL: URL Collabora server uses to call back the backend
# Local dev: http://localhost:3010 | Docker: http://backend:3000
WOPI_PUBLIC_URL=http://localhost:3010

# MinIO object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=auranest-drive
MAX_UPLOAD_BYTES=104857600

# Seed user (local auth only — used by pnpm -C backend prisma:seed)
SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=password123
SEED_USER_NAME=Admin
